#!/usr/bin/env bash
# Reconcile the local DGR vault with its git remote.

set -euo pipefail

VAULT_ROOT="${DGR_VAULT_ROOT:-$HOME/vault}"
REMOTE="${DGR_VAULT_REMOTE:-origin}"
BRANCH="${DGR_VAULT_BRANCH:-main}"
LOG_DIR="${DGR_VAULT_SYNC_LOG_DIR:-$VAULT_ROOT/.vault-system/logs}"
LOCK_FILE="${DGR_VAULT_SYNC_LOCK:-$LOG_DIR/git-sync.lock}"
HOST_LABEL="${DGR_VAULT_SYNC_HOST:-$(hostname -s 2>/dev/null || hostname)}"

usage() {
  cat <<'USAGE'
Usage: dgr-vault-git-sync [--dry-run]

Commit local vault changes, fetch/rebase against the remote main branch, and
push the result. Intended for frequent cron/launchd use on laptop and devbox.

Environment:
  DGR_VAULT_ROOT          Vault checkout, default: ~/vault
  DGR_VAULT_REMOTE        Git remote, default: origin
  DGR_VAULT_BRANCH        Git branch, default: main
  DGR_VAULT_SYNC_LOG_DIR  Log directory, default: ~/vault/.vault-system/logs
USAGE
}

DRY_RUN=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run|-n)
      DRY_RUN=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ ! -d "$VAULT_ROOT/.git" ]]; then
  printf 'vault is not a git checkout: %s\n' "$VAULT_ROOT" >&2
  exit 1
fi

mkdir -p "$(dirname "$LOCK_FILE")" "$LOG_DIR"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  printf 'vault sync already running for %s\n' "$VAULT_ROOT" >&2
  exit 0
fi

cd "$VAULT_ROOT"

current_branch="$(git symbolic-ref --quiet --short HEAD || true)"
if [[ "$current_branch" != "$BRANCH" ]]; then
  printf 'vault sync requires branch %s, found %s\n' "$BRANCH" "${current_branch:-detached HEAD}" >&2
  exit 1
fi

remote_url="$(git remote get-url "$REMOTE" 2>/dev/null || true)"
if [[ -z "$remote_url" ]]; then
  printf 'remote not found: %s\n' "$REMOTE" >&2
  exit 1
fi

run() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf '+ %q' "$1"
    shift
    printf ' %q' "$@"
    printf '\n'
    return 0
  fi
  "$@"
}

resolve_jsonl_union_conflict() {
  local path="$1"
  local tmpdir
  tmpdir="$(mktemp -d)"

  git show ":2:${path}" >"$tmpdir/ours" 2>/dev/null || true
  git show ":3:${path}" >"$tmpdir/theirs" 2>/dev/null || true
  awk 'NF && !seen[$0]++ { print }' "$tmpdir/ours" "$tmpdir/theirs" >"$path"
  rm -rf "$tmpdir"
  git add "$path"
}

try_resolve_metadata_rebase_conflicts() {
  local conflicted
  local path

  while true; do
    conflicted="$(git diff --name-only --diff-filter=U)"
    [[ -n "$conflicted" ]] || return 0

    while IFS= read -r path; do
      case "$path" in
        .vault-system/ops.jsonl)
          printf 'auto-resolving append-only metadata conflict: %s\n' "$path" >&2
          resolve_jsonl_union_conflict "$path"
          ;;
        *)
          printf 'non-metadata conflict requires manual resolution: %s\n' "$path" >&2
          return 1
          ;;
      esac
    done <<<"$conflicted"

    if ! GIT_EDITOR=true git rebase --continue; then
      if [[ -z "$(git diff --name-only --diff-filter=U)" ]]; then
        return 1
      fi
    fi
  done
}

timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

if [[ -n "$(git status --porcelain=v1 -uall)" ]]; then
  run git add -A
  if [[ -n "$(git diff --cached --name-only)" ]]; then
    run env \
      GIT_AUTHOR_NAME="${DGR_VAULT_SYNC_AUTHOR_NAME:-DGR Vault Sync}" \
      GIT_AUTHOR_EMAIL="${DGR_VAULT_SYNC_AUTHOR_EMAIL:-vault-sync@local}" \
      GIT_COMMITTER_NAME="${DGR_VAULT_SYNC_AUTHOR_NAME:-DGR Vault Sync}" \
      GIT_COMMITTER_EMAIL="${DGR_VAULT_SYNC_AUTHOR_EMAIL:-vault-sync@local}" \
      git commit --no-gpg-sign -m "vault sync: ${HOST_LABEL} ${timestamp}"
  fi
fi

run git fetch "$REMOTE" "$BRANCH"

if ! run git rebase "${REMOTE}/${BRANCH}"; then
  if [[ "$DRY_RUN" -eq 0 ]] && try_resolve_metadata_rebase_conflicts; then
    :
  else
    git rebase --abort >/dev/null 2>&1 || true
    printf 'vault sync blocked by rebase conflict; manual resolution needed in %s\n' "$VAULT_ROOT" >&2
    exit 1
  fi
fi

run git push "$REMOTE" "HEAD:${BRANCH}"

git status --short --branch
