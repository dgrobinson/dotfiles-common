#!/usr/bin/env bash
# Install the frequent vault git sync schedule for this machine.

set -euo pipefail

INTERVAL_MINUTES="${1:-1}"
LABEL="com.dgr.vault-git-sync"
RUNNER="$HOME/.local/bin/dgr-vault-git-sync"
VAULT_ROOT="${DGR_VAULT_ROOT:-$HOME/vault}"
LOG_DIR="${DGR_VAULT_SYNC_LOG_DIR:-$VAULT_ROOT/.vault-system/logs}"
LOOP_PID_FILE="$LOG_DIR/vault-git-sync.loop.pid"

usage() {
  cat <<'USAGE'
Usage: install-dgr-vault-sync-schedule [interval_minutes]

Installs a frequent DGR vault git sync loop. Uses launchd on macOS and cron on
Linux/devbox. Default cadence is every 1 minute.
USAGE
}

case "${INTERVAL_MINUTES}" in
  --help|-h)
    usage
    exit 0
    ;;
esac

if ! [[ "$INTERVAL_MINUTES" =~ ^[0-9]+$ ]] || [[ "$INTERVAL_MINUTES" -lt 1 ]]; then
  printf 'interval_minutes must be a positive integer\n' >&2
  exit 2
fi

if [[ ! -x "$RUNNER" ]]; then
  printf 'sync runner is not executable: %s\n' "$RUNNER" >&2
  printf 'run the dotfiles installer first so ~/.local/bin is linked.\n' >&2
  exit 1
fi

mkdir -p "$LOG_DIR"

if [[ "$(uname -s)" == "Darwin" ]]; then
  PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
  mkdir -p "$(dirname "$PLIST")"
  cat >"$PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${RUNNER}</string>
  </array>
  <key>StartInterval</key>
  <integer>$((INTERVAL_MINUTES * 60))</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${LOG_DIR}/vault-git-sync.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>${LOG_DIR}/vault-git-sync.stderr.log</string>
</dict>
</plist>
PLIST
  uid="$(id -u)"
  launchctl bootout "gui/${uid}/${LABEL}" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/${uid}" "$PLIST"
  launchctl kickstart -k "gui/${uid}/${LABEL}"
  printf 'installed launchd job: %s every %s minute(s)\n' "$LABEL" "$INTERVAL_MINUTES"
  exit 0
fi

if ! command -v crontab >/dev/null 2>&1; then
  printf 'crontab is required on non-macOS systems\n' >&2
  exit 1
fi

CRON_EXPR="* * * * *"
if [[ "$INTERVAL_MINUTES" -gt 1 ]]; then
  CRON_EXPR="*/${INTERVAL_MINUTES} * * * *"
fi

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
(crontab -l 2>/dev/null || true) | grep -vF "$LABEL" >"$tmp" || true
printf '%s %s >> %s 2>> %s # %s\n' \
  "$CRON_EXPR" \
  "$RUNNER" \
  "$LOG_DIR/vault-git-sync.stdout.log" \
  "$LOG_DIR/vault-git-sync.stderr.log" \
  "$LABEL" >>"$tmp"
crontab "$tmp"
printf 'installed cron job: %s every %s minute(s)\n' "$LABEL" "$INTERVAL_MINUTES"

if pgrep -x cron >/dev/null 2>&1 || pgrep -x crond >/dev/null 2>&1; then
  exit 0
fi

if [[ -f "$LOOP_PID_FILE" ]]; then
  old_pid="$(cat "$LOOP_PID_FILE" 2>/dev/null || true)"
  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" >/dev/null 2>&1; then
    printf 'cron daemon not detected; fallback loop already running with pid %s\n' "$old_pid"
    exit 0
  fi
fi

nohup /bin/bash -lc "while :; do '$RUNNER' >> '$LOG_DIR/vault-git-sync.stdout.log' 2>> '$LOG_DIR/vault-git-sync.stderr.log'; sleep $((INTERVAL_MINUTES * 60)); done" >/dev/null 2>&1 &
printf '%s\n' "$!" >"$LOOP_PID_FILE"
printf 'cron daemon not detected; started fallback sync loop with pid %s\n' "$!"
